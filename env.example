# Copy to .env and fill in (never commit .env).
# Password for the Angular admin section (/admin/*). Checked via POST /api/admin/verify-password.
ADMIN_PASSWORD=
# Enable exactly one LLM backend below.

# ── CLOUD OPENAI ─────────────────────────────────────────────────────────────
OPENAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── LOCAL OLLAMA ─────────────────────────────────────────────────────────────
# Ollama must be running locally (`ollama serve`). Use an OpenAI-compatible
# base URL ending in /v1. Pull the model once:
#   ollama pull qwen3.5:0.8b
OLLAMA_ENABLED=false
# OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
# OLLAMA_API_KEY=ollama
# OLLAMA_MODEL=qwen3.5:0.8b
# For models like Qwen3 you can append raw JSON extras (optional):
# OLLAMA_EXTRA_BODY_JSON={"chat_template_kwargs":{"enable_thinking":false}}
# OLLAMA_DISABLE_THINKING_TEMPLATE=true

# ── OLLAMA CLOUD ─────────────────────────────────────────────────────────────
# Run large models without a local GPU — Ollama offloads to its cloud service.
# Set OLLAMA_ENABLED=true and configure one of the two approaches below.
# Docs: https://docs.ollama.com/cloud
#
# Option A — Cloud via local Ollama (requires `ollama serve` + `ollama signin`):
#   Pull a cloud model: `ollama pull kimi-k2.6:cloud`
#   OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
#   OLLAMA_MODEL=kimi-k2.6:cloud
#
# Option B — Direct Ollama Cloud API (no local Ollama needed):
#   Create an API key at https://ollama.com/settings/keys
#   OLLAMA_BASE_URL=https://ollama.com/v1
#   OLLAMA_API_KEY=your_api_key_here
#   OLLAMA_MODEL=kimi-k2.6
#
# Cloud models are auto-detected by the :cloud suffix or a non-localhost base URL.
# Local-only parameters (like OLLAMA_DISABLE_THINKING_TEMPLATE) are skipped for cloud.

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local dev (MongoDB Community / Docker on default port):
# MONGODB_URI=mongodb://localhost:27017/
#
# Atlas (cloud): Database → Connect → Drivers → copy connection string.
# Host must look like cluster0.xxxxx.mongodb.net (NOT mongodb.com).
# MONGODB_URI=mongodb+srv://myuser:myPass@cluster0.ab12cd.mongodb.net/?retryWrites=true&w=majority
#
# Migrate legacy spreadsheet/events.json/images once:
#   python -m agent migrate-mongodb
#
# Serve the REST API for the Angular app (dev + deploy):
#   python -m agent api --port 8765

# ── TOPICS ───────────────────────────────────────────────────────────────────
# Multi-topic registry: topics/topics.json (``active`` id selects prompts + data folder).
# Override without editing JSON:
# ACTIVE_TOPIC=live-music-brisbane-gold-coast
#
# Per-topic files live under topics/<id>/:
#   subject_matter.yaml, exclusions.yaml, assets/bg.jpg
#
# Pipeline snapshots default to data/<topic_id>/ (snapshot.json only; run reports are in MongoDB).
# Curated events and poster images live in MongoDB (``db`` in topics.json).
# OUTPUT_DIR=data means the repo data/ root — the agent still writes to the active topic subfolder.
# OUTPUT_DIR=data/live-music-brisbane-gold-coast  (explicit topic folder)
# Or pin a fully custom path: OUTPUT_DIR=D:\MyData\AgentAI
#
# Legacy per-file overrides (optional):
# SUBJECT_MATTER_CONFIG=topics/my-topic/subject_matter.yaml
# EVENT_EXCLUSIONS_CONFIG=topics/my-topic/exclusions.yaml

# Interval for ``agent serve`` (hours only; restart serve after changing).
# SCHEDULE_INTERVAL_HOURS=1

# ── DISPLAY ──────────────────────────────────────────────────────────────────
# IANA timezone for the "Generated" line in research output (default: Australia/Brisbane).
# DISPLAY_TZ=Australia/Sydney

# ── TUNING ───────────────────────────────────────────────────────────────────
# Defaults are tuned for broader search coverage (more queries + more hits per query).
# MAX_SEARCH_QUERIES=8
# Planner search-query LLM: each run samples a random temperature in this range
# (usual creative range is 0–1). Set both to the same value for a fixed temperature.
# PLANNER_TEMPERATURE_MIN=0.0
# PLANNER_TEMPERATURE_MAX=1.0
# Legacy fixed override (used only when MIN/MAX are unset):
# PLANNER_TEMPERATURE=0.85
# SEARCH_DELAY_SEC=1.5
# MAX_DDG_RESULTS_PER_QUERY=10

# Same-site crawl after DuckDuckGo (bounded; uses httpx + BeautifulSoup).
# CRAWL_ENABLED=false
# MAX_CRAWL_SEEDS=5
# MAX_CRAWL_PAGES_TOTAL=28
# MAX_CRAWL_DEPTH=2
# MAX_CRAWL_PAGES_PER_SEED=12
# CRAWL_DELAY_SEC=0.35
# CRAWL_MAX_TEXT_PER_PAGE=38000   # larger excerpts for long listing/calendar HTML
# CURATOR_INPUT_MAX_CHARS=180000  # when clipping, same-site crawl tail is preferred over search head (lower = smaller curator output, less risk of truncation)
# DATA_DIR=data

YOUTUBE_API_KEY=###

# ── DIGITALOCEAN MCP (optional — for Cursor App Platform deploy tools) ───────
# Create a token at https://cloud.digitalocean.com/account/api/tokens
# Also set as a Windows user env var so Cursor can read it on startup, or rely
# on envFile in .cursor/mcp.json loading this .env file.
# DIGITALOCEAN_API_TOKEN=
