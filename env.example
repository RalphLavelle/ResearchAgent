# Copy to .env and fill in (never commit .env).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Markdown output folder (default: your Desktop/AgentAI).
# OUTPUT_DIR=C:\Users\You\Desktop\AgentAI
# Or: AGENT_AI_DIR=...

# Optional tuning
# MAX_SEARCH_QUERIES=6
# SEARCH_DELAY_SEC=1.5
# MAX_DDG_RESULTS_PER_QUERY=5
# SCHEDULE_CONFIG_PATH=config/schedule.yaml
# DATA_DIR=data
